{
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log *)",
      "Bash(curl *)",
      "Read",
      "Edit",
      "Write"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/USER/To_do_list/scripts/sync-todos.js"
          }
        ]
      }
    ]
  }
}